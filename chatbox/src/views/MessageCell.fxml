<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<HBox fx:id="messageRow" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1"
      spacing="8" alignment="TOP_LEFT">
    <ImageView fx:id="avatar" fitWidth="32" fitHeight="32">
        <clip>
            <Circle radius="16" centerX="16" centerY="16" />
        </clip>
    </ImageView>
    <TextFlow fx:id="bubble" styleClass="bubble">
        <children>
            <Text fx:id="messageText" />
        </children>
    </TextFlow>
</HBox>
