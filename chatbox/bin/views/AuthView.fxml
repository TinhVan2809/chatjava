<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controllers.AuthController"
        styleClass="root-pane auth-root">
    <children>
        <HBox maxWidth="1120.0" prefHeight="720.0" styleClass="auth-shell">
            <children>
                <VBox prefWidth="420.0" styleClass="auth-hero">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onBack" styleClass="secondary-button ghost-button"
                                text="Back" />
                        <Label styleClass="hero-eyebrow" text="Realtime Messenger" />
                        <Label styleClass="hero-title" text="Java chat UI refactored for real production work." wrapText="true" />
                        <Label styleClass="hero-copy"
                                text="Ứng dụng trò chuyện trực tuyến. Chúng tôi luôn cung cấp một môi trường phù hợp ứng với thực tiễn của bạn." wrapText="true" />
                        <VBox spacing="10.0" styleClass="hero-points">
                            <children>
                                <Label styleClass="hero-point" text="Reusable chat items and message bubbles" />
                                <Label styleClass="hero-point" text="Real-time private chat, typing, and online presence" />
                                <Label styleClass="hero-point" text="Cleaner separation between view, state, and networking" />
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="36.0" left="36.0" right="36.0" top="36.0" />
                    </padding>
                </VBox>

                <BorderPane maxWidth="520.0" styleClass="auth-card" HBox.hgrow="ALWAYS">
                    <top>
                        <VBox spacing="16.0" BorderPane.alignment="CENTER">
                            <children>
                                <Label styleClass="section-title" text="Sign in or create an account" />
                                <GridPane hgap="12.0" vgap="12.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="70.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                        <ColumnConstraints minWidth="56.0" />
                                        <ColumnConstraints minWidth="130.0" />
                                    </columnConstraints>
                                    <children>
                                        <Label styleClass="field-label" text="Host" />
                                        <TextField fx:id="hostField" promptText="127.0.0.1" styleClass="text-input"
                                                GridPane.columnIndex="1" />
                                        <Label styleClass="field-label" text="Port" GridPane.columnIndex="2" />
                                        <TextField fx:id="portField" promptText="5000" styleClass="text-input"
                                                GridPane.columnIndex="3" />
                                    </children>
                                </GridPane>
                            </children>
                            <padding>
                                <Insets bottom="8.0" left="32.0" right="32.0" top="32.0" />
                            </padding>
                        </VBox>
                    </top>

                    <center>
                        <TabPane styleClass="auth-tabs" tabClosingPolicy="UNAVAILABLE">
                            <tabs>
                                <Tab text="Login">
                                    <content>
                                        <VBox spacing="18.0" styleClass="auth-form">
                                            <children>
                                                <GridPane hgap="12.0" vgap="14.0">
                                                    <columnConstraints>
                                                        <ColumnConstraints minWidth="110.0" />
                                                        <ColumnConstraints hgrow="ALWAYS" />
                                                    </columnConstraints>
                                                    <children>
                                                        <Label styleClass="field-label" text="Username" />
                                                        <TextField fx:id="loginUsernameField" promptText="username"
                                                                styleClass="text-input" GridPane.columnIndex="1" />
                                                        <Label styleClass="field-label" text="Password" GridPane.rowIndex="1" />
                                                        <PasswordField fx:id="loginPasswordField" promptText="Password"
                                                                styleClass="text-input" GridPane.columnIndex="1"
                                                                GridPane.rowIndex="1" />
                                                    </children>
                                                </GridPane>
                                                <Button fx:id="loginButton" maxWidth="1.7976931348623157E308"
                                                        mnemonicParsing="false" onAction="#onLogin"
                                                        styleClass="primary-button" text="Login" />
                                            </children>
                                        </VBox>
                                    </content>
                                </Tab>
                                <Tab text="Register">
                                    <content>
                                        <VBox spacing="18.0" styleClass="auth-form">
                                            <children>
                                                <GridPane hgap="12.0" vgap="14.0">
                                                    <columnConstraints>
                                                        <ColumnConstraints minWidth="110.0" />
                                                        <ColumnConstraints hgrow="ALWAYS" />
                                                    </columnConstraints>
                                                    <children>
                                                        <Label styleClass="field-label" text="Full name" />
                                                        <TextField fx:id="registerNameField" promptText="Your full name"
                                                                styleClass="text-input" GridPane.columnIndex="1" />
                                                        <Label styleClass="field-label" text="Username" GridPane.rowIndex="1" />
                                                        <TextField fx:id="registerUsernameField" promptText="username"
                                                                styleClass="text-input" GridPane.columnIndex="1"
                                                                GridPane.rowIndex="1" />
                                                        <Label styleClass="field-label" text="Password" GridPane.rowIndex="2" />
                                                        <PasswordField fx:id="registerPasswordField" promptText="Password"
                                                                styleClass="text-input" GridPane.columnIndex="1"
                                                                GridPane.rowIndex="2" />
                                                    </children>
                                                </GridPane>
                                                <Button fx:id="registerButton" maxWidth="1.7976931348623157E308"
                                                        mnemonicParsing="false" onAction="#onRegister"
                                                        styleClass="primary-button success-button" text="Create account" />
                                            </children>
                                        </VBox>
                                    </content>
                                </Tab>
                            </tabs>
                        </TabPane>
                    </center>

                    <bottom>
                        <Label fx:id="statusLabel" maxWidth="1.7976931348623157E308" styleClass="status-banner"
                                text="Connect to server and sign in to start chatting." BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="24.0" left="32.0" right="32.0" top="10.0" />
                            </BorderPane.margin>
                        </Label>
                    </bottom>
                </BorderPane>
            </children>
        </HBox>
    </children>
</StackPane>
