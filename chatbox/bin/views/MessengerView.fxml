                    <Button mnemonicParsing="false" styleClass="icon-button">
                        <graphic>
                            <SVGPath content="M24,12c0,.276-.224,.5-.5,.5H.5c-.276,0-.5-.224-.5-.5s.224-.5,.5-.5H23.5c.276,0,.5,.224,.5,.5ZM.5,5H23.5c.276,0,.5-.224,.5-.5s-.224-.5-.5-.5H.5c-.276,0-.5,.224-.5,.5s.224,.5,.5,.5Zm23,14H.5c-.276,0-.5,.224-.5,.5s.224,.5,.5,.5H23.5c.276,0,.5-.224,.5-.5s-.224-.5-.5-.5Z" styleClass="menu-icon"/>
                        </graphic>
                    </Button>
                    <!-- /SETTING -->

                    <!-- LOGO -->
                    <Button mnemonicParsing="false" styleClass="icon-logo">
                        <graphic>
                            <SVGPath content="m20.546,9c1.904,0,3.454-1.55,3.454-3.454,0-2.704-2.02-5.08-4.696-5.463-2.725-.389-5.475.608-7.362,2.664-2.253,2.455-5.349,6.4-7.3,11.024-.096.23-.487.266-.812.199-.679-.138-1.829-.859-1.829-2.691v-2.278c0-.553-.448-1-1-1s-1,.447-1,1v3.51c0,4.826,3.578,8.833,8.324,9.321.543.056,1.104.097,1.676.128v1.041c0,.553.448,1,1,1s1-.447,1-1v-1.003c.694-.042,1.368-.188,2-.444v.447c0,1.103.897,2,2,2h2c.553,0,1-.447,1-1s-.447-1-1-1h-2v-2c-.002-.252-.106-6.254-6.125-7.008-.548-.068-.937-.568-.868-1.116.068-.548.565-.933,1.117-.868,4.73.593,6.814,3.872,7.545,6.63.214-.644.33-1.324.33-2.024v-2.19c.354.236.77.604,1.2,1.177.196.263.496.4.801.4.209,0,.419-.065.599-.2.442-.331.532-.958.2-1.399-1.018-1.358-2.059-1.937-2.8-2.194v-2.207h2.546Z" styleClass="menu-icon"/>
                        </graphic>
                    </Button>
                    <!-- /LOGO -->

                    </children>
            </VBox>

        <VBox prefWidth="340.0" styleClass="sidebar">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="sidebar-header">
                    <children>
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="sidebar-title" text="Messages" />
                                <Label styleClass="sidebar-caption" text="Search and jump between conversations" />
                            </children>
                        </VBox>
                        <Button fx:id="themeToggleButton" mnemonicParsing="false" onAction="#onToggleTheme"
                                styleClass="ghost-button compact-button" text="Dark" />
                    </children>
                </HBox>

                <VBox spacing="12.0" styleClass="search-block">
                    <children>
                        <TextField fx:id="searchField" promptText="Search chats or usernames"
                                styleClass="text-input search-input" />
                    </children>
                    <padding>
                        <Insets bottom="14.0" left="20.0" right="20.0" top="0.0" />
                    </padding>
                </VBox>

                <ListView fx:id="conversationListView" styleClass="conversation-list" VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="profile-card">
                    <children>
                        <HBox fx:id="profileSummaryPane" alignment="CENTER_LEFT" spacing="14.0"
                                onMouseClicked="#onOpenProfile" styleClass="profile-summary" HBox.hgrow="ALWAYS">
                            <children>
                                <StackPane fx:id="currentUserAvatarPane" styleClass="profile-avatar">
                                    <children>
                                        <ImageView fx:id="currentUserAvatarImageView" fitHeight="44.0" fitWidth="44.0"
                                                managed="false" pickOnBounds="true" preserveRatio="true" visible="false" />
                                        <Label fx:id="currentUserAvatarLabel" styleClass="profile-avatar-text" text="ME" />
                                    </children>
                                </StackPane>
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="currentUserNameLabel" styleClass="profile-name" text="Full Name" />
                                        <Label fx:id="currentUsernameLabel" styleClass="profile-handle" text="@username" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Button mnemonicParsing="false" onAction="#onLogout"
                                styleClass="secondary-button compact-button" text="Logout" />
                    </children>
                    <padding>
                        <Insets bottom="18.0" left="20.0" right="20.0" top="18.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
        </HBox>
    </left>

    <center>
        <BorderPane styleClass="chat-panel">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="chat-header">
                    <children>
                        <StackPane fx:id="headerAvatarPane" styleClass="header-avatar">
                            <children>
                                <ImageView fx:id="headerAvatarImageView" fitHeight="44.0" fitWidth="44.0"
                                        managed="false" preserveRatio="true" smooth="true" visible="false" />
                                <Label fx:id="headerAvatarLabel" styleClass="header-avatar-text" text="GR" />
                            </children>
                        </StackPane>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="chatTitleLabel" styleClass="chat-title" text="Community Room" />
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Circle fx:id="chatStatusDot" radius="4.0" styleClass="presence-dot" />
                                        <Label fx:id="chatStatusLabel" styleClass="chat-status" text="0 people online" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="callStatusLabel" managed="false" styleClass="call-status" text="Calling..." visible="false" />
                        <HBox alignment="CENTER_RIGHT" spacing="8.0">
                            <children>
                                <Button fx:id="searchMessagesButton" mnemonicParsing="false" onAction="#onToggleMessageSearch"
                                         styleClass="secondary-button, compact-button, header-icon-button, search-toggle-button"> 
                                    <graphic>
                                        <SVGPath content="M23.854,23.146l-6.449-6.449c1.607-1.775,2.596-4.12,2.596-6.697C20,4.486,15.514,0,10,0S0,4.486,0,10s4.486,10,10,10c2.577,0,4.922-.988,6.697-2.596l6.449,6.449,.707-.707Zm-13.854-4.146C5.038,19,1,14.962,1,10S5.038,1,10,1s9,4.038,9,9-4.037,9-9,9Z" scaleX="0.78" scaleY="0.78" styleClass="header-action-icon" />
                                    </graphic>
                                    <tooltip><Tooltip text="Search messages" /></tooltip>
                                </Button>
                                <Button fx:id="callButton" mnemonicParsing="false" onAction="#onStartCall"
                                     styleClass="secondary-button, compact-button, header-icon-button, call-button"> 
                                    <graphic>
                                        <SVGPath content="M22.27,1.77l-1.12-.98c-1.02-1.02-2.75-1.07-3.85,.05l-1.87,2.45c-1.05,1.05-1.05,2.76,0,3.8l1.49,1.53c-1.62,3.8-4.61,6.8-8.29,8.3l-1.53-1.49c-.51-.51-1.18-.79-1.9-.79s-1.39,.28-1.85,.75l-2.54,1.96c-1.05,1.05-1.05,2.76-.02,3.78l1.02,1.17c1.1,1.1,2.58,1.71,4.19,1.71,7.75,0,18.02-10.28,18.02-18.02,0-1.6-.61-3.09-1.73-4.21ZM5.98,23c-1.34,0-2.57-.5-3.46-1.39l-1.02-1.18c-.66-.66-.66-1.73-.05-2.35l2.54-1.96c.32-.32,.74-.5,1.2-.5s.88,.18,1.2,.5c0,0,1.77,1.73,1.77,1.73,.14,.14,.34,.18,.53,.11,4.17-1.59,7.56-4.98,9.29-9.28,.07-.18,.03-.39-.11-.54l-1.73-1.77c-.66-.66-.66-1.73,.04-2.44l1.87-2.45c.66-.66,1.73-.66,2.42,.02l1.12,.98c.91,.91,1.41,2.14,1.41,3.48,0,7.16-9.86,17.02-17.02,17.02Z" scaleX="0.78" scaleY="0.78" styleClass="header-action-icon" />
                                    </graphic>
                                    <tooltip><Tooltip text="Voice call" /></tooltip>
                                </Button>
                                <Button fx:id="videoCallButton" mnemonicParsing="false" onAction="#onStartVideoCall"
                                      styleClass="secondary-button, compact-button, header-icon-button, video-call-button"> 
                                    <graphic>
                                        <SVGPath content="M24,7.64v8.666c0,.635-.353,1.206-.92,1.489-.238,.119-.493,.177-.747,.177-.353,0-.702-.113-.997-.334l-2.336-2.327v.19c0,2.481-2.019,4.5-4.5,4.5H4.5c-2.481,0-4.5-2.019-4.5-4.5v-7c0-2.481,2.019-4.5,4.5-4.5H14.5c2.481,0,4.5,2.019,4.5,4.5v.157l2.281-2.301c.563-.428,1.23-.489,1.799-.205,.568,.284,.92,.854,.92,1.489Zm-6,.86c0-1.93-1.57-3.5-3.5-3.5H4.5c-1.93,0-3.5,1.57-3.5,3.5v7c0,1.93,1.57,3.5,3.5,3.5H14.5c1.93,0,3.5-1.57,3.5-3.5v-7Zm5-.86c0-.257-.138-.48-.368-.595-.23-.115-.491-.091-.697,.062l-2.936,2.97v3.821l2.989,2.986c.152,.108,.412,.133,.643,.017,.23-.115,.368-.337,.368-.595V7.64Z" scaleX="0.78" scaleY="0.78" styleClass="header-action-icon" />
                                    </graphic>
                                    <tooltip><Tooltip text="Video call" /></tooltip>
                                </Button>
                                <Button fx:id="hangupButton" managed="false" mnemonicParsing="false" onAction="#onHangupCall"
                                        styleClass="secondary-button, compact-button, header-icon-button, call-end-button" visible="false">
                                    <graphic>
                                        <SVGPath content="M6.62 10.79C8.06 13.62 10.38 15.94 13.21 17.38L15.41 15.18C15.69 14.9 16.08 14.82 16.43 14.93C17.55 15.3 18.75 15.5 20 15.5C20.55 15.5 21 15.95 21 16.5V20C21 20.55 20.55 21 20 21C10.61 21 3 13.39 3 4C3 3.45 3.45 3 4 3H7.5C8.05 3 8.5 3.45 8.5 4C8.5 5.25 8.7 6.45 9.07 7.57C9.18 7.92 9.1 8.31 8.82 8.59L6.62 10.79Z" rotate="135.0" scaleX="0.78" scaleY="0.78" styleClass="header-action-icon" />
                                    </graphic>
                                    <tooltip><Tooltip text="End call" /></tooltip>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="18.0" left="24.0" right="24.0" top="22.0" />
                    </padding>
                </HBox>
            </top>

            <center>
                <StackPane styleClass="chat-body">
                    <children>
                        <ScrollPane fx:id="messagesScrollPane" fitToWidth="true" hbarPolicy="NEVER"
                                pannable="true" styleClass="messages-scroll">
                            <content>
                                <VBox fx:id="messagesContainer" spacing="14.0" styleClass="messages-container">
                                    <padding>
                                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <StackPane fx:id="emptyStatePane" styleClass="empty-state">
                            <children>
                                <VBox alignment="CENTER" spacing="10.0" maxWidth="360.0">
                                    <children>
                                        <Label fx:id="emptyStateTitleLabel" styleClass="empty-state-title" text="No messages yet" />
                                        <Label fx:id="emptyStateBodyLabel" styleClass="empty-state-copy"
                                                text="Your first message will show up here." wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>

                        <Button fx:id="newMessagesButton" managed="false" mnemonicParsing="false"
                                onAction="#onJumpToLatestMessages" styleClass="new-messages-button"
                                text="Tin nhắn mới ↓" visible="false">
                            <StackPane.alignment>
                                <javafx.geometry.Pos fx:constant="BOTTOM_CENTER" />
                            </StackPane.alignment>
                            <StackPane.margin>
                                <Insets bottom="18.0" />
                            </StackPane.margin>
                        </Button>
                    </children>
                </StackPane>
            </center>

            <right>
                <VBox fx:id="messageSearchSidebar" managed="false" prefWidth="320.0"
                        styleClass="message-search-sidebar" visible="false">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="message-search-sidebar-header">
                            <children>
                                <Label styleClass="message-search-sidebar-title" text="Search Messages" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#onToggleMessageSearch"
                                        styleClass="ghost-button compact-button message-search-close-button" text="×" />
                            </children>
                        </HBox>
                        <TextField fx:id="messageSearchField" promptText="Search in current conversation"
                                styleClass="text-input message-search-input" />
                        <Label fx:id="messageSearchMetaLabel" styleClass="message-search-meta"
                                text="Type to search in this conversation." wrapText="true" />
                        <ListView fx:id="messageSearchResultsListView" styleClass="message-search-results" VBox.vgrow="ALWAYS" />
                    </children>
                    <padding>
                        <Insets bottom="18.0" left="16.0" right="16.0" top="18.0" />
                    </padding>
                </VBox>
            </right>

            <bottom>
                <VBox fx:id="composerShell" onDragDropped="#onDragDropped" onDragExited="#onDragExited"
                        onDragOver="#onDragOver" spacing="10.0" styleClass="composer-shell">
                    <children>
                        <HBox fx:id="typingIndicatorPane" alignment="CENTER_LEFT" managed="false" spacing="10.0"
                                styleClass="typing-indicator-pane" visible="false">
                            <children>
                                <Label fx:id="typingIndicatorTextLabel" styleClass="typing-indicator-text"
                                        text="typing..." />
                                <StackPane styleClass="typing-indicator-bubble">
                                    <children>
                                        <HBox alignment="CENTER" spacing="6.0">
                                            <children>
                                                <Circle fx:id="typingDotOne" radius="4.0" styleClass="typing-indicator-dot" />
                                                <Circle fx:id="typingDotTwo" radius="4.0" styleClass="typing-indicator-dot" />
                                                <Circle fx:id="typingDotThree" radius="4.0" styleClass="typing-indicator-dot" />
                                            </children>
                                        </HBox>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>
                        <HBox fx:id="replyPreviewPane" alignment="CENTER_LEFT" spacing="10.0" styleClass="reply-composer">
                            <children>
                                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="replyPreviewTitleLabel" styleClass="reply-composer-title" text="Dang tra loi Alice" />
                                        <Label fx:id="replyPreviewBodyLabel" styleClass="reply-composer-body"
                                                text="Noi dung dang duoc tra loi" wrapText="true" />
                                    </children>
                                </VBox>
                                <Button fx:id="clearReplyButton" mnemonicParsing="false" onAction="#onClearReply"
                                        styleClass="ghost-button compact-button reply-composer-close" text="×" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="composer-row">
                            <children>
                                <TextField fx:id="messageInputField" promptText="Write a message and press Enter"
                                        styleClass="text-input composer-input" HBox.hgrow="ALWAYS" />
                                <Button fx:id="sendImageButton" mnemonicParsing="false" onAction="#onSendImage"
                                        styleClass="composer-tool-button" text="" />
                                <Button fx:id="sendEmojiButton" mnemonicParsing="false" onAction="#onSendEmoji"
                                        styleClass="composer-tool-button" text="" />
                                <Button fx:id="sendFileButton" mnemonicParsing="false" onAction="#onSendFile"
                                        styleClass="composer-tool-button" text="" />
                                <Button fx:id="sendButton" mnemonicParsing="false" onAction="#onSendMessage"
                                        styleClass="primary-button" text="Gửi" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="22.0" left="24.0" right="24.0" top="16.0" />
                    </padding>
                </VBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
