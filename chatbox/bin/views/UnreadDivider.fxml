<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
        alignment="CENTER"
        spacing="12.0"
        styleClass="unread-divider">
    <children>
        <Separator styleClass="unread-divider-line" HBox.hgrow="ALWAYS" />
