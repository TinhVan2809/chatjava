<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controllers.ProfilePopupController"
        alignment="TOP_CENTER"
        prefWidth="360.0"
        spacing="18.0"
        styleClass="root-pane,profile-popup-shell">
    <children>
        <HBox alignment="CENTER_LEFT" styleClass="profile-popup-header">
            <children>
                <Label styleClass="profile-popup-title" text="Your Profile" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="closeButton" mnemonicParsing="false" onAction="#onClose"
                        styleClass="ghost-button compact-button profile-popup-close" text="×" />
            </children>
        </HBox>

        <VBox alignment="CENTER" spacing="14.0" styleClass="profile-popup-card">
            <children>
                <StackPane fx:id="avatarPane" styleClass="profile-popup-avatar">
                    <children>
                        <ImageView fx:id="avatarImageView" fitHeight="96.0" fitWidth="96.0"
                                managed="false" pickOnBounds="true" preserveRatio="true" visible="false" />
                        <Label fx:id="avatarFallbackLabel" styleClass="profile-popup-avatar-text" text="ME" />
                    </children>
                </StackPane>

                <VBox alignment="CENTER" spacing="4.0">
                    <children>
                        <Label fx:id="fullNameLabel" styleClass="profile-popup-name" text="Full Name" />
                        <Label fx:id="usernameLabel" styleClass="profile-popup-username" text="@username" />
                    </children>
                </VBox>

                <Label fx:id="statusLabel" styleClass="profile-popup-note" text="Choose a square image for the best result." wrapText="true" />

                <Button fx:id="updateAvatarButton" mnemonicParsing="false" onAction="#onChooseAvatar"
                        styleClass="primary-button" text="Update Avatar" />
            </children>
            <padding>
                <Insets bottom="22.0" left="24.0" right="24.0" top="18.0" />
            </padding>
        </VBox>
    </children>
    <padding>
        <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
    </padding>
</VBox>
